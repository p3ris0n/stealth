            "ActorHeader": []
          }
        ],
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/policies/evaluate": {
      "post": {
        "summary": "Evaluate whether a sender can mail a recipient",
        "responses": {
          "default": {
            "description": ""
          }
        }
      }
    },
    "/postage": {
      "post": {
        "summary": "Submit a postage proof",
        "security": [
          {
            "ActorHeader": []
